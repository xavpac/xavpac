# Copier ce fichier vers .env.local lorsque les vraies API seront connectées.

NEXT_PUBLIC_APP_NAME=XavPac
# Exemples futurs :
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
# WEATHER_API_KEY=
# NOTAM_API_KEY=

# Optionnel et gratuit : compte OpenSky sans carte bancaire.
# Sans ces variables, XavPac reste pleinement fonctionnel avec ADSBDB.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Tous les fournisseurs sont indépendants et désactivables sans modifier le code.
AIRPLANES_LIVE_ENABLED=true
ADSBDB_ENABLED=true
PLANESPOTTERS_ENABLED=true
OPENSKY_ENABLED=true
CELESTRAK_ENABLED=true
